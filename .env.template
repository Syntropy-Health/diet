# AWS Syntropy Integration Development
AWSSecurityClientID=
AWSSecurityClientSecret=

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter Configuration (Primary LLM Provider)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-r1-0528-qwen3-8b:free

# LangSmith Configuration
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=diet-insight-engine

# Postgres Configuration
DB_CONN_URI=postgresql://diet_user:your_password_here@localhost:5432/diet_db

# Milvus Configuration
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# Application Configuration
LOG_LEVEL=INFO
ENVIRONMENT=development
DEBUG=true

# Health Data Processing
MAX_JOURNAL_ENTRIES=1000
SYMPTOM_ANALYSIS_THRESHOLD=0.7
NUTRITION_CONFIDENCE_THRESHOLD=0.6

# ==========================================
# AMAZON SELLING PARTNER API (SP-API)
# ==========================================

# Amazon SP-API Credentials
# Get these from: https://developer-docs.amazon.com/sp-api/docs/registering-your-application
AMAZON_SP_API_CLIENT_ID=your_sp_api_client_id_here
AMAZON_SP_API_CLIENT_SECRET=your_sp_api_client_secret_here
AMAZON_SP_API_REFRESH_TOKEN=your_sp_api_refresh_token_here

# Amazon SP-API Configuration
AMAZON_SP_API_REGION=us-east-1
AMAZON_SP_API_MARKETPLACE_ID=ATVPDKIKX0DER  # US marketplace
AMAZON_SP_API_ENDPOINT=https://sellingpartnerapi-na.amazon.com

# Amazon Associate/Affiliate Configuration
AMAZON_ASSOCIATE_TAG=your_amazon_associate_tag_here
AMAZON_ACCESS_KEY_ID=your_amazon_access_key_id_here
AMAZON_SECRET_ACCESS_KEY=your_amazon_secret_access_key_here

# ==========================================
# AMAZON PRODUCT SEARCH CONFIGURATION
# ==========================================

# Product Search Configuration
AMAZON_MAX_SEARCH_RESULTS=50
AMAZON_MIN_RATING=4.0
AMAZON_MIN_REVIEWS=10
AMAZON_MAX_PRICE_USD=200.00
AMAZON_SEARCH_HOPS=3

# Filtering Thresholds
AMAZON_FILTER_MIN_RATING=4.0
AMAZON_FILTER_MIN_REVIEW_COUNT=50
AMAZON_FILTER_MAX_SCAM_INDICATORS=2
AMAZON_FILTER_VERIFIED_PURCHASES_MIN_PERCENT=70.0

# Refinement Configuration
AMAZON_REFINE_NUTRITION_MATCH_THRESHOLD=0.8
AMAZON_REFINE_TITLE_RELEVANCE_THRESHOLD=0.7
AMAZON_REFINE_DESCRIPTION_RELEVANCE_THRESHOLD=0.6

# ==========================================
# RATE LIMITING AND API QUOTAS
# ==========================================

# Amazon SP-API Rate Limiting
AMAZON_SP_API_RATE_LIMIT_PER_SECOND=10
AMAZON_SP_API_BURST_LIMIT=50
AMAZON_SP_API_RETRY_ATTEMPTS=3
AMAZON_SP_API_RETRY_DELAY=2  # seconds

# ==========================================
# AMAZON TESTING CONFIGURATION
# ==========================================

# Testing Configuration
TEST_AMAZON_SEARCH_QUERIES=vitamin d,omega 3,iron supplement
TEST_SKIP_EXTERNAL_APIS=false
ENABLE_AMAZON_INTEGRATION=true
ENABLE_MOCK_RESPONSES=false
